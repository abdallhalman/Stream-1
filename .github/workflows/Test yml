name: Test
on:
  workflow_dispatch:

jobs:
  test:
    runs-on: ubuntu-latest
    timeout-minutes: 30
    steps:

      - name: Install tools
        run: |
          sudo apt-get install -y ffmpeg
          pip install gdown

      - name: Check cache
        id: cache-media
        uses: actions/cache/restore@v4
        with:
          path: |
            video1.mp4
            video2.mp4
            video3.mp4
            video4.mp4
            video5.mp4
            audio1.mp3
            audio2.mp3
            audio3.mp3
            audio4.mp3
            audio5.mp3
            audio6.mp3
            audio7.mp3
            audio8.mp3
            audio9.mp3
            audio10.mp3
            audio11.mp3
            audio12.mp3
            audio13.mp3
            audio14.mp3
            audio15.mp3
            audio16.mp3
          key: media-files-v4

      - name: Download video files
        if: steps.cache-media.outputs.cache-hit != 'true'
        run: |
          gdown 1NXc6Qzw00ShvoQlZRvSQ-9_xqdyUw2j0 -O video1.mp4
          gdown 1AOyK6tYphq81bt9LC5okcxA0JqNJdR-C -O video2.mp4
          gdown 1841s1wEpXdFHGQTPV8rJaj_736EaFWVB -O video3.mp4
          gdown 1QVMlr8fj3-qOR7EgVCtSxLeFYHADK4fk -O video4.mp4
          gdown 13VykZHBpj6IZRv_l1Adm27UKEYLmKLA_ -O video5.mp4

      - name: Download audio files
        if: steps.cache-media.outputs.cache-hit != 'true'
        run: |
          gdown 1TOMytDgeII2GDspmHZ-kbAis-juK2iqp -O a1.tmp && ffmpeg -i a1.tmp audio1.mp3 -y
          gdown 10Z5lBwM4zr3JsEcd_2KY7vB0qOJRjNjo -O a2.tmp && ffmpeg -i a2.tmp audio2.mp3 -y
          gdown 17nqAmBYExskUmySAzB51NAxic5XJRuLj -O a3.tmp && ffmpeg -i a3.tmp audio3.mp3 -y
          gdown 1IbkCM0FYurEzKBBWB-GYyMVA-Js2zbQM -O a4.tmp && ffmpeg -i a4.tmp audio4.mp3 -y
          gdown 1XkDh8_5rNV8CZtgMdR-82lcWAVPbxwcL -O a5.tmp && ffmpeg -i a5.tmp audio5.mp3 -y
          gdown 1BVe4zBJBYdkSgCpyWG7Xi4iMbbyVX5Eq -O a6.tmp && ffmpeg -i a6.tmp audio6.mp3 -y
          gdown 1F2LQM5tQjJkyA2u_kTzKf3uTm7gS8F_S -O a7.tmp && ffmpeg -i a7.tmp audio7.mp3 -y
          gdown 1qkBtQe6NHlKoThu4W1jIT4Nc7HoEzOef -O a8.tmp && ffmpeg -i a8.tmp audio8.mp3 -y
          gdown 1TXbWo89v0e8RMkwuuwkilB24LdCc0Xkn -O a9.tmp && ffmpeg -i a9.tmp audio9.mp3 -y
          gdown 1pcFXubIlecpZCyWEbVZ-ZXeJbBvemnik -O a10.tmp && ffmpeg -i a10.tmp audio10.mp3 -y
          gdown 1lI1QjxrDFraxniv2Dzvs3O9s0w_kRuqx -O a11.tmp && ffmpeg -i a11.tmp audio11.mp3 -y
          gdown 1HlQRc8k574Uatup7i1Itb8J0AqLOETbG -O a12.tmp && ffmpeg -i a12.tmp audio12.mp3 -y
          gdown 1gkoZQ8Imfxorb25N3mRMpwkf7ZPwJwQU -O a13.tmp && ffmpeg -i a13.tmp audio13.mp3 -y
          gdown 1fK1m2SBkGOw5hjXnM9bpoTcH0jGdp4AL -O a14.tmp && ffmpeg -i a14.tmp audio14.mp3 -y
          gdown 1JbdI4Tpu_EtfYP3ZMjFZdAj42dVBXfoB -O a15.tmp && ffmpeg -i a15.tmp audio15.mp3 -y
          gdown 1UMkrpGqC_E_YB7qmLuBBKRnt2cOOf5HL -O a16.tmp && ffmpeg -i a16.tmp audio16.mp3 -y

      - name: Save cache
        if: steps.cache-media.outputs.cache-hit != 'true'
        uses: actions/cache/save@v4
        with:
          path: |
            video1.mp4
            video2.mp4
            video3.mp4
            video4.mp4
            video5.mp4
            audio1.mp3
            audio2.mp3
            audio3.mp3
            audio4.mp3
            audio5.mp3
            audio6.mp3
            audio7.mp3
            audio8.mp3
            audio9.mp3
            audio10.mp3
            audio11.mp3
            audio12.mp3
            audio13.mp3
            audio14.mp3
            audio15.mp3
            audio16.mp3
          key: media-files-v4

      - name: Test clips
        run: |
          echo "=== Video order ==="
          ls video*.mp4 | shuf > video_list.txt
          cat video_list.txt
          
          echo "=== Audio order ==="
          ls audio*.mp3 | shuf > audio_list.txt
          cat audio_list.txt
          
          echo "=== Testing video clips ==="
          while IFS= read -r file; do
            echo ">>> Testing: $file"
            ffmpeg -fflags +genpts -ss 0 -t 10 -i "$file" -f null - 2>&1 | grep -E "error|Error|invalid|corrupt" || echo "✅ $file OK"
          done < video_list.txt
          
          echo "=== Testing audio clips ==="
          while IFS= read -r file; do
            echo ">>> Testing: $file"
            ffmpeg -fflags +genpts -ss 0 -t 10 -i "$file" -f null - 2>&1 | grep -E "error|Error|invalid|corrupt" || echo "✅ $file OK"
          done < audio_list.txt
          
          echo "=== Testing transitions ==="
          PREV=""
          while IFS= read -r file; do
            if [ -n "$PREV" ]; then
              echo ">>> Transition: $PREV → $file"
              ffmpeg -fflags +genpts \
              -ss 0 -t 10 -i "$PREV" \
              -ss 0 -t 10 -i "$file" \
              -filter_complex "[0:v][1:v]concat=n=2:v=1[v]" \
              -map "[v]" -f null - 2>&1 | grep -E "error|Error|invalid|corrupt" || echo "✅ OK"
            fi
            PREV="$file"
          done < video_list.txt
